# --- Supabase (Auth) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# --- Stripe ---
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
# Price ID for Checkout (e.g. price_123)
STRIPE_PRICE_ID=

# Public base URL for redirects (optional; falls back to request origin)
NEXT_PUBLIC_APP_URL=

# --- Signal API (collector / foundry service) ---
# Where the dashboard fetches /events, /digest, /status, /highlights from.
# For local dev, you can point this at your backend service (e.g. http://localhost:8787)
NEXT_PUBLIC_SIGNAL_API_BASE_URL=

# Optional: override default docs/payload-examples directory for mock data
SIGNAL_SAMPLE_DIR=

# Optional shared secret if you want to protect /api/webhooks/provision
PROVISION_WEBHOOK_SECRET=

# Telegram bot token for push notifications
TELEGRAM_BOT_TOKEN=
